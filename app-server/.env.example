NODE_ENV=production
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=elixopay
DB_USER=postgres
DB_PASSWORD=securepassword

# Security - CORS
# Comma-separated list of allowed origins. MUST include your frontend domain.
FRONTEND_ALLOWED_ORIGINS=https://elixopay.com,https://www.elixopay.com

# JWT
JWT_SECRET=replace_with_strong_random_string
JWT_REFRESH_SECRET=replace_with_another_strong_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

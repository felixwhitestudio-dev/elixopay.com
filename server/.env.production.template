# ============================================
# Elixopay API — Environment Variables
# Google Cloud Production Configuration
# ============================================

# Server
NODE_ENV=production
PORT=3000
APP_URL=https://app.elixopay.com

# Database (Google Cloud SQL — PostgreSQL)
DATABASE_URL=postgresql://elixopay:YOUR_DB_PASSWORD@CLOUD_SQL_IP:5432/elixopay

# Authentication
JWT_SECRET=GENERATE_A_STRONG_64_CHAR_SECRET_HERE
JWT_EXPIRES_IN=7d

# KBank API Credentials
KBANK_CONSUMER_ID=
KBANK_CONSUMER_SECRET=
KBANK_API_KEY=
KBANK_PARTNER_ID=
KBANK_API_URL=https://openapi.kasikornbank.com

# BBL API Credentials (when ready)
BBL_API_KEY=
BBL_API_SECRET=
BBL_API_URL=

# Omise (Card Payments)
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@elixopay.com

# Error Monitoring (Sentry)
SENTRY_DSN=

# Google OAuth (for merchant login)
GOOGLE_CLIENT_ID=

# Redis (Google Cloud Memorystore)
REDIS_URL=redis://MEMORYSTORE_IP:6379

# Security
CORS_ORIGINS=https://elixopay.com,https://www.elixopay.com,https://app.elixopay.com,https://api.elixopay.com

# Logging
LOG_LEVEL=info

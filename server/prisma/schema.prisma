// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  merchantId String   @unique          // e.g. "ELXP-A7K2M9" — unique, non-guessable merchant identifier
  email      String   @unique
  password  String
  firstName String?
  lastName  String?
  role            String    @default("user") // user, admin
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isActive        Boolean   @default(true)
  
  // Security / Email Verification
  isEmailVerified    Boolean   @default(false)
  verifyToken        String?
  verifyTokenExpires DateTime?
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  
  // KYC Fields
  kycStatus       String    @default("unverified") // unverified, pending, verified, rejected
  kycIdCardUrl    String?
  kycStatementUrl String?
  kycSelfieUrl    String?  // Selfie with document (BOT required)
  kycRejectionReason String? // Admin rejection note shown to user
  kycSubmittedAt  DateTime?
  kycVerifiedAt   DateTime?
  kycReviewedBy   String?  // Email of admin who approved/rejected — BOT audit trail

  // Bank Account Fields (BOT-compliant: locked after KYC approval)
  bankName          String?  // e.g. KBANK, SCB, BBL, KTB, BAY, TTB
  bankAccountNumber String?
  bankAccountName   String?  // Must match KYC name
  bankVerified      Boolean  @default(false) // Locked to true after admin KYC approval

  // Two-Factor Authentication
  twoFactorSecret   String?  // Encrypted TOTP secret
  twoFactorEnabled  Boolean  @default(false)

  wallet          Wallet?
  transactions    Transaction[]
  auditLogs       AuditLog[]
  bankChangeRequests BankAccountChangeRequest[]
  apiKeys         ApiKey[]
  webhooks        WebhookEndpoint[]
  customers       Customer[]
  products        Product[]
  gatewayConfigs  MerchantGatewayConfig[]
  notifications   Notification[]
}

model BankAccountChangeRequest {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  // New requested values
  newBankName          String
  newAccountNumber     String
  newAccountName       String
  reason               String  // Reason for requesting the change
  status               String  @default("pending") // pending, approved, rejected
  adminNote            String? // Admin's response note
  createdAt            DateTime @default(now())
  resolvedAt           DateTime?
}

model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Decimal  @default(0.00)
  testBalance Decimal @default(0.00)
  usdtBalance Decimal @default(0.00)
  currency  String   @default("THB")
  updatedAt DateTime @updatedAt
}

model Transaction {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  amount         Decimal
  type           String   // DEPOSIT, WITHDRAW, EXCHANGE
  status         String   // PENDING, COMPLETED, FAILED
  reference      String?  // Bank reference or Slip ID
  idempotencyKey String?  @unique // Critical for stability
  metadata       String?  // JSON string
  
  // Payment Orchestrator Fields
  provider        String?  // 'kbank', 'omise', 'bbl', 'mock' — which gateway processed this
  providerChargeId String? // Charge/Transaction ID from the gateway
  paymentMethod   String?  // 'qr', 'card', 'bank_transfer', 'wallet'

  // Tracking Fields for Refunds
  refundedAmount Decimal  @default(0.00) // Tracks how much has been refunded
  parentId       Int?     // Links a REFUND transaction to its original PAYMENT
  parent         Transaction?  @relation("TransactionRefunds", fields: [parentId], references: [id])
  refunds        Transaction[] @relation("TransactionRefunds")
  
  invoice        Invoice?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SystemSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model ApiKey {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  name      String   // e.g., "Production Key", "Test Key"
  keyPrefix String   // To show in UI (e.g., ep_prod_xxxx...)
  keyHash   String   // Hashed version of the secret key for security
  mode      String   @default("test") // test, live
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  lastUsed  DateTime?
}

model WebhookEndpoint {
  id          String   @id @default(uuid())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  url         String
  secret      String   // Used to sign webhook payloads so merchant can verify
  events      String   // JSON array of subscribed events: ["payment.success", "payment.failed"]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model IdempotencyKey {
  id              Int      @id @default(autoincrement())
  key             String   @unique
  userId          Int?
  requestPath     String
  requestMethod   String
  requestPayload  String?  // Storing as JSON string
  responseStatus  Int?
  responseBody    String?  // Storing as JSON string
  isLocked        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Customer {
  id             String   @id @default(uuid())
  merchantId     Int
  merchant       User     @relation(fields: [merchantId], references: [id])
  name           String
  email          String
  phone          String?
  subscriptions  Subscription[]
  invoices       Invoice[]
  metadata       String?
  createdAt      DateTime @default(now())
}

model Product {
  id          String   @id @default(uuid())
  merchantId  Int
  merchant    User     @relation(fields: [merchantId], references: [id])
  name        String
  description String?
  prices      Price[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Price {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  amount        Decimal
  currency      String   @default("THB")
  interval      String   // "month", "year", "week"
  intervalCount Int      @default(1)
  isActive      Boolean  @default(true)
  subscriptions Subscription[]
  createdAt     DateTime @default(now())
}

model Subscription {
  id                   String   @id @default(uuid())
  customerId           String
  customer             Customer @relation(fields: [customerId], references: [id])
  priceId              String
  price                Price    @relation(fields: [priceId], references: [id])
  status               String   @default("active") // active, past_due, canceled
  currentPeriodStart   DateTime @default(now())
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  invoices             Invoice[]
  createdAt            DateTime @default(now())
}

model Invoice {
  id              String   @id @default(uuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  transactionId   Int?     @unique // Links to the actual Elixopay Transaction for payment
  transaction     Transaction? @relation(fields: [transactionId], references: [id])
  amountDue       Decimal
  status          String   @default("open") // open, paid, void, uncollectible
  dueDate         DateTime
  paidAt          DateTime?
  createdAt       DateTime @default(now())
}

model MerchantGatewayConfig {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  provider    String   // 'kbank', 'omise', 'bbl'
  isActive    Boolean  @default(true)
  config      String   // Encrypted JSON: { clientId, clientSecret, ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, provider])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String   // payment, kyc, payout, system, security
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  String?  // JSON: { transactionId, amount, etc. }
  createdAt DateTime @default(now())
}

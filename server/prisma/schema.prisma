generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int                        @id @default(autoincrement())
  merchantId             String                     @unique
  email                  String                     @unique
  password               String
  firstName              String?
  lastName               String?
  role                   String                     @default("user")
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  isActive               Boolean                    @default(true)
  isEmailVerified        Boolean                    @default(false)
  verifyToken            String?
  verifyTokenExpires     DateTime?
  resetPasswordToken     String?
  resetPasswordExpires   DateTime?
  kycStatus              String                     @default("unverified")
  kycIdCardUrl           String?
  kycStatementUrl        String?
  kycSelfieUrl           String?
  kycRejectionReason     String?
  kycSubmittedAt         DateTime?
  kycVerifiedAt          DateTime?
  kycReviewedBy          String?
  bankName               String?
  bankAccountNumber      String?
  bankAccountName        String?
  bankVerified           Boolean                    @default(false)
  twoFactorSecret        String?
  twoFactorEnabled       Boolean                    @default(false)
  stripeAccountId        String?                    @unique
  stripeAccountStatus    String                     @default("none")
  stripeDetailsSubmitted Boolean                    @default(false)
  stripePayoutsEnabled   Boolean                    @default(false)
  stripeChargesEnabled   Boolean                    @default(false)
  stripeConnectedAt      DateTime?
  apiKeys                ApiKey[]
  auditLogs              AuditLog[]
  bankChangeRequests     BankAccountChangeRequest[]
  customers              Customer[]
  gatewayConfigs         MerchantGatewayConfig[]
  notifications          Notification[]
  products               Product[]
  stripePayouts          StripePayout[]
  transactions           Transaction[]
  wallet                 Wallet?
  webhooks               WebhookEndpoint[]
}

model StripeEvent {
  id        String   @id
  type      String
  processed Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now())
}

model StripePayout {
  id               Int      @id @default(autoincrement())
  userId           Int
  stripeTransferId String?  @unique
  amount           Decimal
  currency         String   @default("THB")
  status           String   @default("pending")
  method           String   @default("stripe_transfer")
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
}

model BankAccountChangeRequest {
  id               Int       @id @default(autoincrement())
  userId           Int
  newBankName      String
  newAccountNumber String
  newAccountName   String
  reason           String
  status           String    @default("pending")
  adminNote        String?
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?
  user             User      @relation(fields: [userId], references: [id])
}

model Wallet {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  balance     Decimal  @default(0.00)
  testBalance Decimal  @default(0.00)
  currency    String   @default("THB")
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id               Int           @id @default(autoincrement())
  userId           Int
  amount           Decimal
  type             String
  status           String
  reference        String?
  idempotencyKey   String?       @unique
  metadata         String?
  provider         String?
  providerChargeId String?
  paymentMethod    String?
  refundedAmount   Decimal       @default(0.00)
  parentId         Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  invoice          Invoice?
  parent           Transaction?  @relation("TransactionRefunds", fields: [parentId], references: [id])
  refunds          Transaction[] @relation("TransactionRefunds")
  user             User          @relation(fields: [userId], references: [id])
}

model SystemSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model ApiKey {
  id        String    @id @default(uuid())
  userId    Int
  name      String
  keyPrefix String
  keyHash   String
  mode      String    @default("test")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  lastUsed  DateTime?
  user      User      @relation(fields: [userId], references: [id])
}

model WebhookEndpoint {
  id        String   @id @default(uuid())
  userId    Int
  url       String
  secret    String
  events    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model IdempotencyKey {
  id             Int      @id @default(autoincrement())
  key            String   @unique
  userId         Int?
  requestPath    String
  requestMethod  String
  requestPayload String?
  responseStatus Int?
  responseBody   String?
  isLocked       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Customer {
  id            String         @id @default(uuid())
  merchantId    Int
  name          String
  email         String
  phone         String?
  metadata      String?
  createdAt     DateTime       @default(now())
  merchant      User           @relation(fields: [merchantId], references: [id])
  invoices      Invoice[]
  subscriptions Subscription[]
}

model Product {
  id          String   @id @default(uuid())
  merchantId  Int
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  prices      Price[]
  merchant    User     @relation(fields: [merchantId], references: [id])
}

model Price {
  id            String         @id @default(uuid())
  productId     String
  amount        Decimal
  currency      String         @default("THB")
  interval      String
  intervalCount Int            @default(1)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  product       Product        @relation(fields: [productId], references: [id])
  subscriptions Subscription[]
}

model Subscription {
  id                 String    @id @default(uuid())
  customerId         String
  priceId            String
  status             String    @default("active")
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  invoices           Invoice[]
  customer           Customer  @relation(fields: [customerId], references: [id])
  price              Price     @relation(fields: [priceId], references: [id])
}

model Invoice {
  id             String       @id @default(uuid())
  subscriptionId String
  customerId     String
  transactionId  Int?         @unique
  amountDue      Decimal
  status         String       @default("open")
  dueDate        DateTime
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  customer       Customer     @relation(fields: [customerId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  transaction    Transaction? @relation(fields: [transactionId], references: [id])
}

model MerchantGatewayConfig {
  id        Int      @id @default(autoincrement())
  userId    Int
  provider  String
  isActive  Boolean  @default(true)
  config    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model agencies {
  id                                                        String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  parent_id                                                 String?                @db.Uuid
  name                                                      String                 @db.VarChar(255)
  code                                                      String                 @unique @db.VarChar(50)
  status                                                    String?                @default("active") @db.VarChar(30)
  metadata                                                  Json?
  created_at                                                DateTime?              @default(now()) @db.Timestamp(6)
  updated_at                                                DateTime?              @default(now()) @db.Timestamp(6)
  agencies                                                  agencies?              @relation("agenciesToagencies", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_agencies                                            agencies[]             @relation("agenciesToagencies")
  agency_balances                                           agency_balances[]
  agency_members                                            agency_members[]
  commission_overrides                                      commission_overrides[]
  commission_rules                                          commission_rules[]
  ledger_entries_ledger_entries_agency_idToagencies         ledger_entries[]       @relation("ledger_entries_agency_idToagencies")
  ledger_entries_ledger_entries_related_agency_idToagencies ledger_entries[]       @relation("ledger_entries_related_agency_idToagencies")
  merchant_sites                                            merchant_sites[]
  payout_accounts                                           payout_accounts[]
  withdrawal_requests                                       withdrawal_requests[]
}


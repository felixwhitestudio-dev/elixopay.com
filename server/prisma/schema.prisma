model ledger_entries {
  id                                                  BigInt               @id @default(autoincrement())
  agency_id                                           String               @db.Uuid
  type                                                String               @db.VarChar(50)
  direction                                           String               @db.Char(1)
  amount                                              Decimal              @db.Decimal(18, 2)
  currency                                            String               @default("THB") @db.VarChar(3)
  status                                              String               @default("PENDING") @db.VarChar(20)
  payment_id                                          String?              @db.Uuid
  withdrawal_request_id                               BigInt?
  related_agency_id                                   String?              @db.Uuid
  description                                         String?
  available_at                                        DateTime?            @db.Timestamp(6)
  created_at                                          DateTime?            @default(now()) @db.Timestamp(6)
  agencies_ledger_entries_agency_idToagencies         agencies             @relation("ledger_entries_agency_idToagencies", fields: [agency_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  agencies_ledger_entries_related_agency_idToagencies agencies?            @relation("ledger_entries_related_agency_idToagencies", fields: [related_agency_id], references: [id], onUpdate: NoAction)
  withdrawal_requests                                 withdrawal_requests? @relation(fields: [withdrawal_request_id], references: [id], onUpdate: NoAction)

  @@index([agency_id], map: "idx_ledger_entries_agency")
  @@index([created_at(sort: Desc)], map: "idx_ledger_entries_created")
  @@index([payment_id], map: "idx_ledger_entries_payment")
  @@index([status], map: "idx_ledger_entries_status")
}

model merchant_settings {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String    @unique(map: "unique_merchant_settings_user") @db.Uuid
  business_name         String?   @db.VarChar(255)
  business_type         String?   @db.VarChar(100)
  business_email        String?   @db.VarChar(255)
  business_phone        String?   @db.VarChar(50)
  business_website      String?   @db.VarChar(500)
  business_address      String?
  default_currency      String?   @default("THB") @db.VarChar(10)
  auto_payout           String?   @default("manual") @db.VarChar(20)
  payment_description   String?
  test_mode             Boolean?  @default(true)
  auto_capture          Boolean?  @default(true)
  notify_email_success  Boolean?  @default(true)
  notify_email_fail     Boolean?  @default(true)
  notify_email_payout   Boolean?  @default(true)
  notify_daily_summary  Boolean?  @default(false)
  notify_sms_high_value Boolean?  @default(false)
  notify_sms_security   Boolean?  @default(true)
  timezone              String?   @default("Asia/Bangkok") @db.VarChar(50)
  date_format           String?   @default("DD/MM/YYYY") @db.VarChar(20)
  number_format         String?   @default("th-TH") @db.VarChar(20)
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  updated_at            DateTime? @default(now()) @db.Timestamptz(6)
  users                 users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_merchant_settings_user")
}

